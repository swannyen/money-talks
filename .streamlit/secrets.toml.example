# Copy to secrets.toml for local development (do not commit secrets.toml).
# On Streamlit Cloud: App settings → Secrets → paste the same key/value.

APP_PASSWORD = "choose-a-strong-password"

# Use the Supabase *pooler* URL (IPv4). Direct db.*.supabase.co is IPv6-only.
# Dashboard: Project Settings → Database → Connection pooling → Transaction mode
DATABASE_URL = "postgresql://postgres.<project-ref>:YOUR-PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Comma-separated lists (or TOML arrays in Streamlit secrets)
PORTFOLIOS = "Tiger,MooMoo,Vickers"
CURRENCIES = "SGD,USD,HKD,EUR,JPY"
BASE_CURRENCY = "SGD"
